{
  "name": "StumpScore",
  "description": "Premium cricket analytics platform",
  "repository": "https://github.com/yourusername/stumpscore",
  "keywords": ["cricket", "analytics", "sports", "nodejs", "react"],
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "env": {
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "MONGO_URI": {
      "description": "MongoDB connection string",
      "required": true
    },
    "JWT_SECRET": {
      "description": "JWT secret key for authentication",
      "generator": "secret",
      "required": true
    },
    "RAZORPAY_KEY_ID": {
      "description": "Razorpay API key ID",
      "required": true
    },
    "RAZORPAY_KEY_SECRET": {
      "description": "Razorpay API key secret",
      "required": true
    },
    "RAZORPAY_WEBHOOK_SECRET": {
      "description": "Razorpay webhook secret",
      "required": true
    },
    "SMTP_USER": {
      "description": "SMTP email address",
      "required": true
    },
    "SMTP_PASS": {
      "description": "SMTP password",
      "required": true
    },
    "CLIENT_URL": {
      "description": "Frontend URL",
      "required": false
    },
    "ALLOWED_ORIGINS": {
      "description": "Comma-separated list of allowed CORS origins",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    {
      "plan": "mongolab:sandbox",
      "as": "MONGODB"
    }
  ],
  "scripts": {
    "postdeploy": "echo 'Deployment successful!'"
  }
}
