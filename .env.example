# StumpScore Environment Variables

# Environment
NODE_ENV=development

# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/stumpscore
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/stumpscore

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=StumpScore <noreply@stumpscore.com>

# Frontend URL
CLIENT_URL=http://localhost:3000

# External APIs
CRICKET_API_KEY=00ba4444-6577-435e-a241-02719e3c82e5

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
